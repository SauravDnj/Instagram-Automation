# Instagram Automation Configuration
# 100% FREE - No API Keys Required!

# Instagram Credentials (ONLY thing you need!)
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Application Settings
DEBUG_MODE=false
LOG_LEVEL=INFO
DATABASE_PATH=data/instagram_automation.db

# Scheduler Settings
TIMEZONE=UTC
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60

# Security
ENCRYPTION_KEY=generate_a_secure_key_here
